# Copy to .env and fill in real values. .env is gitignored.

# Required: Anthropic API key for the agent and judge.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model overrides. Defaults are claude-opus-4-7 for both.
# Used to flip to Sonnet/Haiku for downgrade experiments without code changes.
# WIKI_QA_AGENT_MODEL=claude-opus-4-7
# WIKI_QA_JUDGE_MODEL=claude-opus-4-7
